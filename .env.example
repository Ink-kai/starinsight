# 复制为 .env.local 后填入实际值；Vercel Preview/Production 请在 Dashboard 的 Environment Variables 中配置。

# ─── 站点 ───
NEXT_PUBLIC_APP_NAME=AI 紫微命盘报告
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── AI 推理（OpenAI 兼容协议，当前预发布主路径使用 DeepSeek）───
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ─── 管理与风控 ───
# 至少 32 位随机字符串；不要提交真实 token。
ADMIN_TOKEN=replace-with-at-least-32-random-characters
RATE_LIMIT_ENABLED=true

# ─── 报告计费与存储 ───
REPORT_PRICE=19.9
REPORT_STORE=supabase
SUPABASE_URL=https://your-project.supabase.co
# 仅服务端使用：不要添加 NEXT_PUBLIC_ 前缀，不要暴露到客户端。
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── 或用其他 OpenAI 兼容模型（当前 Vercel 预发布 checklist 不使用）───
# AI_PROVIDER=mimo
# MIMO_API_KEY=your-api-key
# MIMO_BASE_URL=https://your-provider/v1
# MIMO_MODEL=model-name
