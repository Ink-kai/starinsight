# 复制为 .env.local 后填入实际值

# ─── 应用基础 ───
NEXT_PUBLIC_APP_NAME=AI 紫微命盘报告
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ATTRIBUTION_TEXT=Based on Renhuai123/ziwei-doushu, MIT License.

# ─── AI 推理（当前默认 DeepSeek OpenAI-compatible）───
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ─── 支付占位 / 管理接口 ───
ADMIN_TOKEN=change-me
REPORT_PRICE=49

# ─── 报告存储 ───
# 本地开发默认 json；生产部署推荐 supabase。
REPORT_STORE=json
# REPORT_STORE_DIR=data/reports

# Supabase Postgres（仅服务端使用，严禁添加 NEXT_PUBLIC 前缀）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
